{
  "name": "fiuba-reviews",
  "private": true,
  "version": "3.0.0",
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@lucide/svelte": "^0.562.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.13",
    "svelte-check": "^4.4.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@ethercorps/sveltekit-og": "^4.2.1",
    "@fontsource/google-sans-code": "^5.2.3",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@valibot/i18n": "^1.0.0",
    "@vercel/functions": "^3.4.3",
    "bits-ui": "^2.16.3",
    "fuse.js": "^7.1.0",
    "postgres": "^3.4.8",
    "posthog-js": "^1.360.2",
    "svelte-turnstile": "^0.11.0",
    "valibot": "^1.3.0"
  },
  "prettier": {
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": false,
    "trailingComma": "none",
    "printWidth": 100,
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-svelte",
      "prettier-plugin-tailwindcss"
    ],
    "importOrder": [
      "^\\$env",
      "",
      "<TYPES>",
      "",
      "^@?svelte",
      "^\\$",
      "",
      "<THIRD_PARTY_MODULES>",
      "^@fontsource",
      "",
      "^[./]"
    ],
    "importOrderSafeSideEffects": [
      "^@fontsource/"
    ],
    "overrides": [
      {
        "files": "*.svelte",
        "options": {
          "parser": "svelte"
        }
      }
    ],
    "tailwindStylesheet": "./src/routes/layout.css"
  }
}
